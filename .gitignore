# ============================================
# Data files (too large / protected)
# ============================================

# Meal window data
ae_python_code/meal_windows/

# CSV data files (but not the scripts).
# Recursive pattern survives the ohiot1dm/ and diatrend/ namespacing under each output root.
analysis_data/**/*.csv
combined_results/**/*.csv

# Excel workbooks are never committed. DiaTrend fixtures are generated at test time
# into pytest tmp_path, not tracked in git.
*.xlsx

# R data files
*.RData
*.rda
*.rds

# Pickle / serialized
*.pkl
*.pickle
*.joblib
*.npy
*.npz

# HDF5 / models
*.h5
*.hdf5
*.ckpt*
*.pb

# ============================================
# Results / Outputs (regenerable)
# ============================================

# Weights (generated)
analysis_data/weights/

# Mediation results from HPC are regenerable and ignored. The committed
# manuscript figures/tables/grids under */figures/ are already tracked, so
# updates to them still commit; brand-new files there need `git add -f`.
mediation_results/

# Figures (all generated)
results_visualizations/images/

# Tables
results_visualizations/tables/
# ============================================
# HPC / Cluster job scripts (contain local paths / personal info)
# ============================================
cma_cluster/*.sub
cma_cluster/*.sh

# ============================================
# HPC / Cluster logs
# ============================================
logs/
slurm-*.out
slurm-*.err
*.out
*.err

# ============================================
# IDE / Editor
# ============================================
.vscode/
.idea/
*.Rproj
*.swp
*.swo
*~

# ============================================
# OS generated
# ============================================
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
Desktop.ini

# Raw data (OhioT1DM XML files)
OhioT1DM/2018/
OhioT1DM/2020/

# Raw data (DiaTrend Excel workbooks, populated only on HPC3)
DiaTrend/**

# Generated data summaries
results_visualizations/data_summary/

# Experiment result CSVs (regenerable from autoencoder runs)
visualizations/incremental_data_experiment/data/

# Paper visualizations outputs (regenerable via compose_paper_visualizations.py)
visualizations/paper_visualizations/

# Manuscript — NEVER commit (npj revision in progress). See memory: never-commit-manuscript
npj_Digital_Medicine_Manuscript_Copy_with_table_pdf.pdf
/*.pdf

# Manuscript Overleaf source folder — NEVER commit (npj revision)
npj_Digital_Medicine_Manuscript_Copy_with_table_pdf/
